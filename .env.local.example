# Google Sheets API Configuration
# Create a service account at https://console.cloud.google.com
# Share the sheet with the service account email
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"boligscanner@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Optional: Anthropic API key for neighborhood narrative generation
ANTHROPIC_API_KEY=sk-ant-...

# Development
NODE_ENV=development
